# it-landscape environment template
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# WARNING:
# - Never commit .env, .env.local, .env.production or real secrets.
# - Never use default demo accounts, passwords, tokens or secrets in production.

###############################################################################
# Local development
###############################################################################

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-local-dev-secret-at-least-32-chars
AUTH_ENABLED=true

###############################################################################
# Optional NetBox integration
###############################################################################

# If NETBOX_URL and NETBOX_TOKEN are set, infrastructure/network APIs can read
# NetBox instead of local JSON files.
# NETBOX_URL=http://localhost:8080
# NETBOX_TOKEN=replace-with-local-netbox-api-token
# NETBOX_TRIGRAMME_TAG_PREFIX=app:

###############################################################################
# Local NetBox bootstrap, Docker profile "netbox"
###############################################################################

NETBOX_SECRET_KEY=replace-with-local-netbox-secret-key-at-least-50-chars
NETBOX_SUPERUSER_NAME=admin
NETBOX_SUPERUSER_EMAIL=admin@example.local
NETBOX_SUPERUSER_PASSWORD=password
NETBOX_DB_WAIT_TIMEOUT=120
NETBOX_DB_WAIT_DEBUG=0
NETBOX_CSRF_TRUSTED_ORIGINS=http://localhost:8080 https://localhost:8080 http://127.0.0.1:8080 https://127.0.0.1:8080

###############################################################################
# Branding
###############################################################################

NEXT_PUBLIC_LOGO_URL=/logo-gcs.png
NEXT_PUBLIC_ORG_NAME=Organisation de démonstration
NEXT_PUBLIC_APP_TITLE=Cartographie du Système d'Information

###############################################################################
# Production / staging secrets
###############################################################################

# In production, replace every value above and prefer an external secret manager.
# NEXTAUTH_SECRET must be unique, strong and private.
# NETBOX_TOKEN must be a real scoped NetBox token.
# NETBOX_SUPERUSER_PASSWORD must not be "password".
# Replace demo users in data/auth/access-rules.json before exposing the app.

# Azure AD / Entra ID, recommended for production SSO
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
